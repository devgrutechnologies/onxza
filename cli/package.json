{
  "name": "onxza",
  "version": "0.1.0",
  "description": "ONXZA CLI \u2014 AI Company Operating System. Run agent fleets, manage tickets, enforce quality, and orchestrate AI companies from the terminal.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "DevGru Technology Products",
    "email": "hello@onxza.com",
    "url": "https://onxza.com"
  },
  "homepage": "https://onxza.com",
  "bugs": {
    "url": "https://github.com/devgrutechnologies/onxza/issues",
    "email": "hello@onxza.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devgrutechnologies/onxza.git",
    "directory": "cli"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "bin": {
    "onxza": "bin/onxza.js"
  },
  "main": "src/program.js",
  "files": [
    "bin/",
    "src/",
    "LICENSE.md",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node bin/onxza.js",
    "dev": "node bin/onxza.js",
    "test": "node bin/onxza.js --version && node bin/onxza.js help",
    "test:ci": "node bin/onxza.js --version && node bin/onxza.js --json status || true",
    "prepublishOnly": "npm test",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "test:coverage": "c8 --reporter=text --reporter=lcov node bin/onxza.js --version && node bin/onxza.js help",
    "test:coverage:ci": "c8 --reporter=text --reporter=lcov --lines 70 --functions 70 --branches 70 node bin/onxza.js --version && node bin/onxza.js help"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "keywords": [
    "onxza",
    "faails",
    "ai",
    "agent",
    "cli",
    "devgru",
    "llm",
    "autonomous",
    "company-os",
    "agent-fleet"
  ],
  "devDependencies": {
    "c8": "^11.0.0"
  },
  "c8": {
    "reporter": [
      "text",
      "lcov"
    ],
    "exclude": [
      "test/**",
      "node_modules/**"
    ],
    "lines": 70,
    "functions": 70,
    "branches": 70
  }
}
