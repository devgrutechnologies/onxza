{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "onxza-training-record-v1",
  "title": "ONXZA-LLM Training Record",
  "description": "Single training example for ONXZA-LLM. All records must be anonymized before inclusion.",
  "type": "object",
  "required": ["id", "source", "version", "created_at", "input", "output", "metadata"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^onxza-train-(routing|fvp|shared_learning)-[a-f0-9]{8}$",
      "description": "Unique record ID. Format: onxza-train-{source}-{8char-hash}"
    },
    "source": {
      "type": "string",
      "enum": ["routing", "fvp", "shared_learning"],
      "description": "Data source type"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Schema version"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 timestamp of record creation"
    },
    "input": {
      "type": "object",
      "required": ["instruction", "context", "task_type"],
      "properties": {
        "instruction": {
          "type": "string",
          "minLength": 10,
          "description": "What the model is being asked to decide or predict"
        },
        "context": {
          "type": "string",
          "minLength": 10,
          "description": "Relevant context for the decision (anonymized)"
        },
        "task_type": {
          "type": "string",
          "enum": [
            "code_generation",
            "content_writing",
            "research",
            "analysis",
            "routing",
            "verification",
            "planning",
            "data_processing",
            "communication",
            "pattern_application"
          ]
        }
      }
    },
    "output": {
      "type": "object",
      "required": ["reasoning", "decision", "confidence"],
      "properties": {
        "reasoning": {
          "type": "string",
          "minLength": 50,
          "description": "The correct reasoning chain that leads to the decision"
        },
        "decision": {
          "type": "string",
          "minLength": 5,
          "description": "The correct action, answer, or recommendation"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["source", "fvp_result", "loop_count", "anonymized"],
      "properties": {
        "source": { "type": "string" },
        "fvp_result": {
          "type": "string",
          "enum": ["pass", "fail", "escalated", "n/a"]
        },
        "loop_count": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "was_optimal": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "quality_tier": {
          "type": "number",
          "enum": [1, 2, 3],
          "description": "1=high quality (first-pass, high confidence), 2=good, 3=acceptable"
        },
        "anonymized": {
          "type": "boolean",
          "const": true,
          "description": "Must be true — no record enters training without anonymization"
        },
        "anonymization_pass": {
          "type": "boolean",
          "description": "Did the record pass the anonymization regex scan?"
        }
      }
    }
  },
  "additionalProperties": false
}
