{
  "name": "@onxza/core",
  "version": "0.1.0",
  "description": "ONXZA Core Library — shared business logic for the ONXZA CLI and server",
  "license": "SEE LICENSE IN ../../LICENSE.md",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist/", "schemas/", "templates/"],
  "scripts": {
    "build":     "tsup",
    "dev":       "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test":      "vitest run"
  },
  "dependencies": {
    "ajv":          "^8.17.0",
    "ajv-formats":  "^3.0.0",
    "mustache":     "^4.2.0",
    "simple-git":   "^3.27.0",
    "yaml":         "^2.6.0"
  },
  "devDependencies": {
    "typescript":    "^5.7.0",
    "tsup":          "^8.3.0",
    "vitest":        "^2.1.0",
    "@types/node":   "^22.0.0",
    "@types/mustache": "^4.2.0"
  }
}
