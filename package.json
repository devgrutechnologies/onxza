{
  "name": "onxza-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "ONXZA — AI Company Operating System (monorepo root)",
  "license": "SEE LICENSE IN LICENSE.md",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build":      "pnpm -r build",
    "dev":        "pnpm -r --parallel dev",
    "typecheck":  "pnpm -r typecheck",
    "test":       "pnpm -r test",
    "lint":       "pnpm -r lint",
    "clean":      "pnpm -r exec -- rm -rf dist node_modules",
    "core:build": "pnpm --filter @onxza/core build",
    "cli:build":  "pnpm --filter onxza build",
    "cli:dev":    "pnpm --filter onxza dev"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
